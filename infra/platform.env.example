# Local Airflow metadata DB
AIRFLOW_DB_USER=
AIRFLOW_DB_PASSWORD=

# Airflow admin credentials
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=
AIRFLOW_ADMIN_EMAIL=admin@rescue-ai.local

# Application DB (Supabase pooler) — passed to batch containers via DockerOperator
DB_DSN=

# S3 (Yandex Object Storage) — passed to batch containers
ARTIFACTS_S3_ENDPOINT=
ARTIFACTS_S3_REGION=
ARTIFACTS_S3_ACCESS_KEY_ID=
ARTIFACTS_S3_SECRET_ACCESS_KEY=
ARTIFACTS_S3_BUCKET=
ARTIFACTS_S3_PREFIX=missions
