# Postgres (required; no defaults for secrets)
POSTGRES_ADMIN_USER=
POSTGRES_ADMIN_PASSWORD=
POSTGRES_DEFAULT_DB=postgres
POSTGRES_AIRFLOW_PASSWORD=
POSTGRES_APP_USER=rescue_app
POSTGRES_APP_PASSWORD=

# Airflow UI
AIRFLOW_ADMIN_USER=
AIRFLOW_ADMIN_PASSWORD=
AIRFLOW_ADMIN_EMAIL=

# Grafana UI
GRAFANA_ADMIN_USER=
GRAFANA_ADMIN_PASSWORD=

# Batch mission pipeline
BATCH_RUNTIME_ENV=local
BATCH_MISSION_ID=demo_mission
BATCH_CODE_VERSION=dev
BATCH_MODEL_VERSION=yolov8n_baseline_multiscale
BATCH_VALIDATION_MIN_ACCURACY=0.75
BATCH_MISSION_ROOT=/opt/airflow/data/missions
BATCH_ARTIFACT_ROOT=/opt/airflow/data/artifacts
BATCH_STATUS_PATH=/opt/airflow/data/status/runs.json
BATCH_POSTGRES_DSN=

# Shared S3 settings (single naming for API + batch).
ARTIFACTS_S3_ENDPOINT=
ARTIFACTS_S3_REGION=
ARTIFACTS_S3_ACCESS_KEY_ID=
ARTIFACTS_S3_SECRET_ACCESS_KEY=
ARTIFACTS_S3_BUCKET=
ARTIFACTS_S3_PREFIX=batch

# Optional explicit overrides. Usually keep unset and rely on BATCH_RUNTIME_ENV:
# BATCH_ARTIFACT_BACKEND=s3|local
# BATCH_STATUS_BACKEND=postgres|json
# Optional compatibility overrides for batch-specific naming:
# BATCH_S3_ENDPOINT=
# BATCH_S3_BUCKET=
# BATCH_S3_PREFIX=
# BATCH_S3_ACCESS_KEY=
# BATCH_S3_SECRET_KEY=
# BATCH_S3_REGION=
