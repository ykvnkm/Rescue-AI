# Airflow metadata DB DSN (for one-DB setup set equal to DB_DSN)
AIRFLOW_DB_DSN=

# Docker socket group id on host (for non-root Airflow + DockerOperator)
DOCKER_GID=

# Airflow UI
AIRFLOW_ADMIN_USER=
AIRFLOW_ADMIN_PASSWORD=
AIRFLOW_ADMIN_EMAIL=

# Batch mission pipeline
BATCH_IMAGE=<batch-image-ref>

# Shared app/batch database DSN
DB_DSN=

# Shared S3 settings (single naming for API + batch).
ARTIFACTS_S3_ENDPOINT=
ARTIFACTS_S3_REGION=
ARTIFACTS_S3_ACCESS_KEY_ID=
ARTIFACTS_S3_SECRET_ACCESS_KEY=
ARTIFACTS_S3_BUCKET=
ARTIFACTS_S3_PREFIX=missions
