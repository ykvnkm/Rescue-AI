# =============================================================================
# Rescue-AI platform env file (template)
#
# Скопируй этот файл в infra/platform.env и подставь реальные значения.
# infra/platform.env находится в .gitignore и никогда не коммитится.
#
# Все значения в проде приходят из GitHub Secrets через CI/CD. Этот файл —
# транспортный слой между secret-store и контейнерами, больше ничего.
#
# Секреты Airflow прокидываются через штатный механизм — переменные
# окружения с префиксом AIRFLOW_CONN_<NAME>: Airflow автоматически
# регистрирует их как Connections при старте scheduler/webserver.
# В DAG-коде обращение только через BaseHook.get_connection(...).
# Документация: Airflow → "Storing connections in environment variables".
# =============================================================================

# ── Airflow metadata DB (локальная, используется только самим Airflow) ──────
AIRFLOW_DB_USER=
AIRFLOW_DB_PASSWORD=

# ── Airflow admin UI credentials ────────────────────────────────────────────
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=
AIRFLOW_ADMIN_EMAIL=admin@rescue-ai.local

# ── Application Postgres (Supabase pooler) ─────────────────────────────────
# Регистрируется как Airflow Connection `rescue_app_db`.
# В DAG: BaseHook.get_connection("rescue_app_db").get_uri()
AIRFLOW_CONN_RESCUE_APP_DB=

# ── S3 (Yandex Object Storage) ─────────────────────────────────────────────
# Регистрируется как Airflow Connection `rescue_s3` (conn_type=aws).
# Формат URI:
#   aws://<ACCESS_KEY>:<SECRET_KEY>@/?endpoint_url=<URL_ENC>&region_name=<REGION>&bucket=<BUCKET>&prefix=<PREFIX>
# endpoint_url должен быть URL-encoded (https:// → https%3A%2F%2F).
AIRFLOW_CONN_RESCUE_S3=
