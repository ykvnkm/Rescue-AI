# Postgres
POSTGRES_ADMIN_USER=postgres
POSTGRES_ADMIN_PASSWORD=postgres
POSTGRES_DEFAULT_DB=postgres
POSTGRES_AIRFLOW_PASSWORD=airflow
POSTGRES_EXPORTER_USER=postgres_exporter
POSTGRES_EXPORTER_PASSWORD=postgres_exporter

# MinIO (S3-compatible)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_DEFAULT_BUCKET=rescue-artifacts

# Airflow UI
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW_ADMIN_EMAIL=admin@example.com

# Grafana UI
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Batch mission pipeline
BATCH_RUNTIME_ENV=local
BATCH_MISSION_ID=demo_mission
BATCH_CODE_VERSION=dev
BATCH_MODEL_VERSION=yolov8n_baseline_multiscale
BATCH_ARTIFACT_BACKEND=local
BATCH_STATUS_BACKEND=json
BATCH_MISSION_ROOT=/opt/airflow/data/missions
BATCH_ARTIFACT_ROOT=/opt/airflow/data/artifacts
BATCH_STATUS_PATH=/opt/airflow/data/status/runs.json
BATCH_POSTGRES_DSN=postgresql://rescue_app:rescue_app@postgres:5432/rescue_app
BATCH_S3_ENDPOINT=http://minio:9000
BATCH_S3_BUCKET=rescue-artifacts
BATCH_S3_PREFIX=batch
BATCH_S3_ACCESS_KEY=minioadmin
BATCH_S3_SECRET_KEY=minioadmin
BATCH_S3_REGION=us-east-1
