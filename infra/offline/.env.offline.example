# Field-station offline / hybrid profile (ADR-0007).
# Copy to `.env.offline` on the station and adjust passwords.

# ── Deployment profile ──────────────────────────────────────────────
# offline = no sync to cloud
# hybrid  = local-first + sync-worker drains outbox to remote
DEPLOYMENT_MODE=offline

# ── Local Postgres (offline + hybrid) ───────────────────────────────
OFFLINE_DB_USER=rescue
OFFLINE_DB_PASSWORD=change-me-in-the-field
OFFLINE_DB_NAME=rescue_ai
OFFLINE_DB_PORT=5432

# ── Local MinIO (offline + hybrid) ──────────────────────────────────
OFFLINE_S3_ACCESS_KEY=rescueadmin
OFFLINE_S3_SECRET_KEY=change-me-in-the-field
OFFLINE_S3_BUCKET=rescue-artifacts
OFFLINE_S3_PORT=9000
OFFLINE_S3_CONSOLE_PORT=9001

# ── Remote sync targets (hybrid only) ───────────────────────────────
DEPLOYMENT_REMOTE_DB_DSN=
DEPLOYMENT_REMOTE_S3_ENDPOINT=
DEPLOYMENT_REMOTE_S3_REGION=ru-central1
DEPLOYMENT_REMOTE_S3_ACCESS_KEY_ID=
DEPLOYMENT_REMOTE_S3_SECRET_ACCESS_KEY=
DEPLOYMENT_REMOTE_S3_BUCKET=
DEPLOYMENT_SYNC_BATCH_SIZE=50
DEPLOYMENT_SYNC_INTERVAL_SEC=10
DEPLOYMENT_SYNC_MAX_ATTEMPTS=10
DEPLOYMENT_SYNC_PROCESSING_TIMEOUT_SEC=120

# ── App ─────────────────────────────────────────────────────────────
APP_ENV=field
APP_PORT=8000
APP_LOG_LEVEL=INFO
ONLINE_IMAGE=rescue-ai/online:latest

# ── RPi link (mTLS — see scripts/security/) ─────────────────────────
RPI_BASE_URL=https://rpi.local:9100
RPI_MISSIONS_DIR=/home/pi/missions
RPI_RTSP_PORT=8554
TLS_MODE=mtls
TLS_CA_CERT_PATH=/app/certs/station-root-ca.crt
TLS_CLIENT_CERT_PATH=/app/certs/gcs-client.crt
TLS_CLIENT_KEY_PATH=/app/certs/gcs-client.key
