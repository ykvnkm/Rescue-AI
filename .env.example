# ── API / Database ───────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
DB_DSN=postgresql://<user>:<password>@<host>:5432/<db>

# ── S3-compatible Storage ────────────────────────────────────
ARTIFACTS_S3_ENDPOINT=https://<s3-endpoint>
ARTIFACTS_S3_REGION=<s3-region>
ARTIFACTS_S3_ACCESS_KEY_ID=<s3-access-key-id>
ARTIFACTS_S3_SECRET_ACCESS_KEY=<s3-secret-access-key>
ARTIFACTS_S3_BUCKET=<s3-bucket>
ARTIFACTS_S3_PREFIX=missions

# ── Raspberry Pi source ──────────────────────────────────────
RPI_BASE_URL=http://<rpi-host>:<rpi-port>
RPI_MISSIONS_DIR=/home/<user>/missions
RPI_RTSP_PORT=<rpi-rtsp-port>
RPI_RTSP_PATH_PREFIX=live
RPI_TIMEOUT_SEC=10
