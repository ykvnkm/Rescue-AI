# Runtime
LOG_LEVEL=
SERVICE_VERSION=

# Режим хранения артефактов: локальный | s3
# Если выбран режим `s3`, но отсутствуют необходимые переменные S3,
# сервис автоматически переключается на локальное хранилище.
ARTIFACTS_MODE=local
ARTIFACTS_LOCAL_ROOT=runtime/artifacts

# Частное хранилище артефактов S3 (опционально)
ARTIFACTS_S3_ENDPOINT=https://storage.yandexcloud.net
ARTIFACTS_S3_REGION=ru-central1
ARTIFACTS_S3_ACCESS_KEY_ID=
ARTIFACTS_S3_SECRET_ACCESS_KEY=
ARTIFACTS_S3_BUCKET=

# Local mission path
MISSION_DIR=
