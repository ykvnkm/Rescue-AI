# ── Режим работы ───────────────────────────────────────────────
# default — прямая запись (S3 + remote PG напрямую)
# offline_first — сначала локально, потом sync-worker догружает
APP_MODE=offline_first

# Локальный путь к папке миссии (должна содержать images/ и annotations/)
MISSION_DIR=./artifacts/public

# Опционально: версия сервиса для метаданных отчетов
SERVICE_VERSION=dev

# ── Локальный Postgres (на дроне / edge-устройстве) ───────────
APP_POSTGRES_DB=
APP_POSTGRES_USER=
APP_POSTGRES_PASSWORD=
APP_POSTGRES_PORT=
APP_POSTGRES_AUTO_MIGRATE=true
APP_POSTGRES_READY_TIMEOUT_SEC=30

# ── Локальное файловое хранилище ──────────────────────────────
ARTIFACTS_BACKEND=local
ARTIFACTS_LOCAL_ROOT=runtime/artifacts

# ── Удалённый Postgres (наземная станция / облако) ────────────

SYNC_REMOTE_POSTGRES_DSN=


# ── Удалённый S3 ─────────────────────────────────────────────
ARTIFACTS_S3_ENDPOINT=https://storage.yandexcloud.net
ARTIFACTS_S3_REGION=ru-central1
ARTIFACTS_S3_ACCESS_KEY_ID=
ARTIFACTS_S3_SECRET_ACCESS_KEY=
ARTIFACTS_S3_BUCKET=
ARTIFACTS_S3_STRICT=true

# ── Sync worker ───────────────────────────────────────────────
SYNC_ENABLED=true
SYNC_POLL_INTERVAL_SEC=10
SYNC_BATCH_SIZE=50
SYNC_BACKOFF_INITIAL_SEC=5
SYNC_BACKOFF_MAX_SEC=300
SYNC_STUCK_TIMEOUT_SEC=60
SYNC_DELETE_LOCAL_AFTER_SYNC=false
SYNC_S3_PREFIX=missions

# ── Batch (Airflow pipeline) ─────────────────────────────────
BATCH_ARTIFACT_BACKEND=local
BATCH_STATUS_BACKEND=json
BATCH_POSTGRES_DSN=
BATCH_ARTIFACT_ROOT=/opt/airflow/data/artifacts
BATCH_STATUS_PATH=/opt/airflow/data/status/runs.json
BATCH_MISSION_ROOT=/opt/airflow/data/missions
BATCH_S3_PREFIX=batch
