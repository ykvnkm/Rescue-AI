# Локальный путь к папке миссии, где лежат images/ и annotations/
MISSION_DIR=

# Необязательная версия сервиса, которая будет включаться в отчёты миссии
SERVICE_VERSION=

# Хранилище артефактов миссии (кадры/отчёты). Артефакты не сохраняются в Postgres.
# Режим по умолчанию сохраняет поддержку S3 с автоматическим fallback на локальное хранилище.
ARTIFACTS_MODE=s3
ARTIFACTS_S3_ENDPOINT=https://storage.yandexcloud.net
ARTIFACTS_S3_REGION=ru-central1
ARTIFACTS_S3_ACCESS_KEY_ID=
ARTIFACTS_S3_SECRET_ACCESS_KEY=
ARTIFACTS_S3_BUCKET=
ARTIFACTS_S3_STRICT=true

# Локальная корневая папка, используемая при ARTIFACTS_MODE=local
# или когда для S3 не заданы учётные данные
ARTIFACTS_LOCAL_ROOT=runtime/artifacts

# Backend-репозиторий для missions/alerts/frame_events: memory | postgres
APP_REPOSITORY_BACKEND=memory

# Локальные настройки Postgres для API, Alembic и интеграционных тестов pytest.
# В режиме memory оставляй их пустыми. Если APP_POSTGRES_DSN задан,
# он имеет приоритет над полями HOST/PORT/DB/USER/PASSWORD ниже.
APP_POSTGRES_DSN=
APP_POSTGRES_HOST=127.0.0.1
APP_POSTGRES_PORT=5432
APP_POSTGRES_DB=rescue_ai
APP_POSTGRES_USER=rescue_ai
APP_POSTGRES_PASSWORD=

# Вспомогательные настройки старта Docker для режима postgres
APP_POSTGRES_AUTO_MIGRATE=true
APP_POSTGRES_READY_TIMEOUT_SEC=30
