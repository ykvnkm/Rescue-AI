# Локальный путь к папке миссии (должна содержать images/ и annotations/)
MISSION_DIR=

# Опционально: версия сервиса для метаданных отчетов
SERVICE_VERSION=

# DSN для online API (если APP_REPOSITORY_BACKEND=postgres)
DB_DSN=

# S3-хранилище артефактов online-сервиса (кадры/репорты)
# Допустимые значения backend: local | s3
ARTIFACTS_BACKEND=s3
ARTIFACTS_S3_ENDPOINT=https://storage.yandexcloud.net
ARTIFACTS_S3_REGION=ru-central1
ARTIFACTS_S3_ACCESS_KEY_ID=
ARTIFACTS_S3_SECRET_ACCESS_KEY=
ARTIFACTS_S3_BUCKET=
ARTIFACTS_S3_STRICT=true

# Локальный путь для хранения артефактов, если S3-ключи не заданы
ARTIFACTS_LOCAL_ROOT=runtime/artifacts

# Batch storage backend:
# - local: пишет в BATCH_ARTIFACT_ROOT
# - s3: использует единый S3-конфиг ARTIFACTS_S3_*
BATCH_ARTIFACT_BACKEND=local
BATCH_STATUS_BACKEND=json
BATCH_POSTGRES_DSN=
BATCH_ARTIFACT_ROOT=/opt/airflow/data/artifacts
BATCH_STATUS_PATH=/opt/airflow/data/status/runs.json
BATCH_MISSION_ROOT=/opt/airflow/data/missions

# Batch S3 namespace в бакете
BATCH_S3_PREFIX=batch
