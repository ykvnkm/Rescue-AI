# Runtime
LOG_LEVEL=
SERVICE_VERSION=

# Локальный путь к папке миссии. Должен содержать папки: images/ и annotations/
MISSION_DIR=

# Private S3-compatible storage for mission artifacts
ARTIFACTS_S3_ENDPOINT=https://storage.yandexcloud.net
ARTIFACTS_S3_REGION=ru-central1
ARTIFACTS_S3_ACCESS_KEY_ID=
ARTIFACTS_S3_SECRET_ACCESS_KEY=
ARTIFACTS_S3_BUCKET=rescue-ai-mission-artifacts