# Local path to a mission directory with images/ and annotations/
MISSION_DIR=

# Optional service version included in mission reports
SERVICE_VERSION=

# Mission artifact storage (frames/reports). Artifacts do not go to Postgres.
# Default mode keeps S3 support with automatic fallback to local storage.
ARTIFACTS_MODE=s3
ARTIFACTS_S3_ENDPOINT=https://storage.yandexcloud.net
ARTIFACTS_S3_REGION=ru-central1
ARTIFACTS_S3_ACCESS_KEY_ID=
ARTIFACTS_S3_SECRET_ACCESS_KEY=
ARTIFACTS_S3_BUCKET=
ARTIFACTS_S3_STRICT=true

# Local root used when ARTIFACTS_MODE=local or when S3 credentials are absent
ARTIFACTS_LOCAL_ROOT=runtime/artifacts

# Repository backend for missions/alerts/frame_events: memory | postgres
APP_REPOSITORY_BACKEND=memory

# Local Postgres settings for the API, Alembic and pytest integration tests.
# Leave these empty in memory mode. APP_POSTGRES_DSN, when set, overrides
# the HOST/PORT/DB/USER/PASSWORD fields below.
APP_POSTGRES_DSN=
APP_POSTGRES_HOST=127.0.0.1
APP_POSTGRES_PORT=5432
APP_POSTGRES_DB=rescue_ai
APP_POSTGRES_USER=rescue_ai
APP_POSTGRES_PASSWORD=

# Docker startup helpers for postgres mode
APP_POSTGRES_AUTO_MIGRATE=true
APP_POSTGRES_READY_TIMEOUT_SEC=30
